# MongoDB Atlas M0 — obtener en cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/tma?retryWrites=true&w=majority

# NextAuth v5 — generar con: openssl rand -base64 33
AUTH_SECRET=your-secret-here

# URL de la app (para producción en Vercel)
# AUTH_URL=https://your-app.vercel.app
